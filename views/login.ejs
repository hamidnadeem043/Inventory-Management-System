<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login — Inventory</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="login-wrapper">
    <div class="glass-white login-card">

        <div class="login-logo">📦</div>
        <h1 class="login-title">Inventory Manager</h1>
        <p class="login-sub">Sign in to your dashboard</p>

        <% if(error){ %>
        <div class="error-msg">⚠️ <%= error %></div>
        <% } %>

        <form method="POST" action="/login">
            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control" placeholder="Enter username" required autofocus />
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Enter password" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:14px; font-size:1rem; margin-top:0.5rem;">
                Sign In →
            </button>
        </form>

        <p style="text-align:center; margin-top:1.5rem; font-size:0.8rem; color:#aaa;">
            USER: Hamid Pass: hamid123
            Made only for admin
            
        </p>
    </div>
</div>
</body>
</html>